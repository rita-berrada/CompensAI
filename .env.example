# ---- Core ----
ENVIRONMENT=local
LOG_LEVEL=INFO

# Comma-separated. Example: "http://localhost:3000,https://*.lovable.app"
CORS_ORIGINS=http://localhost:3000

# ---- Supabase (server-side) ----
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SCHEMA=public
SUPABASE_TIMEOUT_SECONDS=15

# ---- n8n webhooks (Agent 1) ----
# If set, FastAPI will require this header on intake/vendor_response:
#   X-CompensAI-Webhook-Secret: <value>
N8N_WEBHOOK_SECRET=

# Where FastAPI should POST to ask n8n to send the approved draft.
AGENT1_SEND_WEBHOOK_URL=

# ---- Terms & conditions confirmation agent ----
# Table/field to scan (default table=terms_cond and field=terms_cond).
TERMS_COND_TABLE=terms_cond
TERMS_COND_FIELD=terms_cond
TERMS_COND_ID_FIELD=id
TERMS_COND_TO_EMAIL=client.compensai@gmail.com

# Comma-separated candidate recipient columns.
TERMS_COND_RECIPIENT_FIELDS=user_email,email,to_email

# Exact email content.
TERMS_COND_EMAIL_SUBJECT=Terms and Conditions
TERMS_COND_EMAIL_BODY=Thank you for accepting terms and conditions

# Preferred: webhook sender (falls back to AGENT1_SEND_WEBHOOK_URL when empty).
TERMS_COND_SEND_WEBHOOK_URL=
TERMS_COND_SEND_TIMEOUT_SECONDS=20

# Optional SMTP fallback (used only when webhook URL is not set).
SMTP_HOST=
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# Mark-sent controls (to avoid duplicate emails).
TERMS_COND_MARK_SENT=true
TERMS_COND_SENT_FLAG_FIELDS=terms_cond_email_sent,confirmation_email_sent,email_sent,notification_sent
TERMS_COND_SENT_AT_FIELDS=terms_cond_email_sent_at,confirmation_email_sent_at,email_sent_at,notification_sent_at
TERMS_COND_MAX_ROWS_PER_RUN=200
TERMS_COND_POLL_INTERVAL_SECONDS=30

# ---- Admin endpoints (optional; not safe for browser apps) ----
# If set, FastAPI will require:
#   X-CompensAI-Admin-Key: <value>
ADMIN_API_KEY=

# ---- Agent 2 LLM (Anthropic Claude) ----
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest
ANTHROPIC_TIMEOUT_SECONDS=30

# ---- Stripe (Agent 3, optional) ----
STRIPE_SECRET_KEY=
STRIPE_SUCCESS_URL=https://example.com/success
STRIPE_CANCEL_URL=https://example.com/cancel

# Success fee percentage (0.2 = 20%)
SUCCESS_FEE_RATE=0.2
