{
  "flight": {
    "legal_instrument": "Regulation (EC) No 261/2004",
    "hooks": [
      "Compensation analysis is triggered for arrival delay of 3 hours or more, unless extraordinary circumstances apply.",
      "Typical fixed compensation bands are EUR 250 / EUR 400 / EUR 600 depending on flight distance."
    ],
    "delay_compensation_threshold_hours": 3,
    "compensation_brackets": [
      {"max_distance_km": 1500, "amount_eur": 250},
      {"max_distance_km": 3500, "amount_eur": 400},
      {"max_distance_km": null, "amount_eur": 600}
    ],
    "missing_info_fields": ["arrival_delay_hours", "flight_date", "flight_number"]
  },
  "rail": {
    "legal_instrument": "Regulation (EU) 2021/782",
    "hooks": [
      "Delay compensation baseline: 25% of ticket price for 60-119 minutes delay.",
      "Delay compensation baseline: 50% of ticket price for 120+ minutes delay."
    ],
    "delay_compensation_bands_minutes": [
      {"min_delay_minutes": 60, "percent_ticket_price": 25},
      {"min_delay_minutes": 120, "percent_ticket_price": 50}
    ],
    "missing_info_fields": ["arrival_delay_minutes", "travel_date", "train_number"]
  },
  "bus_coach": {
    "legal_instrument": "Regulation (EU) No 181/2011",
    "hooks": [
      "Core rerouting/refund safeguards generally apply to long-distance regular services of 250 km or more.",
      "Cancellation or delay of at least 120 minutes can trigger rerouting/refund rights for covered services."
    ],
    "minimum_distance_km": 250,
    "major_delay_minutes": 120,
    "primary_rights": ["rerouting", "refund"],
    "missing_info_fields": ["journey_distance_km", "departure_delay_minutes", "travel_date"]
  },
  "sea": {
    "legal_instrument": "Regulation (EU) No 1177/2010",
    "hooks": [
      "Compensation for delay is linked to both scheduled journey duration and actual arrival delay.",
      "Typical compensation percentages are 25% and 50% of ticket price at higher delay bands."
    ],
    "arrival_delay_thresholds": [
      {"max_journey_hours": 4, "min_delay_minutes": 60, "percent_ticket_price": 25},
      {"max_journey_hours": 4, "min_delay_minutes": 120, "percent_ticket_price": 50},
      {"max_journey_hours": 8, "min_delay_minutes": 120, "percent_ticket_price": 25},
      {"max_journey_hours": 8, "min_delay_minutes": 240, "percent_ticket_price": 50},
      {"max_journey_hours": 24, "min_delay_minutes": 180, "percent_ticket_price": 25},
      {"max_journey_hours": 24, "min_delay_minutes": 360, "percent_ticket_price": 50},
      {"max_journey_hours": null, "min_delay_minutes": 360, "percent_ticket_price": 25},
      {"max_journey_hours": null, "min_delay_minutes": 720, "percent_ticket_price": 50}
    ],
    "missing_info_fields": ["scheduled_journey_hours", "arrival_delay_minutes", "travel_date"]
  },
  "parcel_delivery": {
    "legal_instrument": "Directive 2011/83/EU (consumer rights)",
    "hooks": [
      "If no delivery date is agreed, trader should deliver within 30 days from contract conclusion.",
      "If trader fails to deliver on time, consumer can grant additional time and then terminate for refund if still undelivered."
    ],
    "default_delivery_days_if_unspecified": 30,
    "refund_after_termination_days": 14,
    "requires_additional_period_before_termination": true,
    "missing_info_fields": ["purchase_date", "promised_delivery_date", "order_id"]
  },
  "package_travel": {
    "legal_instrument": "Directive (EU) 2015/2302",
    "hooks": [
      "Cancellation by organiser can trigger traveller refund rights.",
      "Refunds are typically due within 14 days after termination where applicable."
    ],
    "refund_after_termination_days": 14,
    "missing_info_fields": ["booking_reference", "departure_date", "amount_paid_eur"]
  }
